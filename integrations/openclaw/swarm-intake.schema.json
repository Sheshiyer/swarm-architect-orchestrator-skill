{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenClaw Swarm Intake",
  "type": "object",
  "required": ["idea"],
  "properties": {
    "idea": {
      "type": "string",
      "minLength": 8,
      "description": "User's idea statement for swarm planning"
    },
    "planning_depth": {
      "type": "string",
      "enum": ["lean", "standard", "deeply_detailed"],
      "default": "standard"
    },
    "delivery_mode": {
      "type": "string",
      "enum": ["prototype", "production", "hardening"],
      "default": "prototype"
    },
    "release_model": {
      "type": "string",
      "enum": ["single_milestone", "phased_rollout"],
      "default": "single_milestone"
    },
    "quality_bar": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "default": "medium"
    },
    "team_topology": {
      "type": "string",
      "enum": ["solo", "small_squad", "multi_squad"],
      "default": "solo"
    },
    "timeline": {
      "type": "string",
      "description": "Requested delivery timeline"
    },
    "initial_tasks": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^T[0-9]{3}$"
      },
      "default": ["T001", "T002", "T003"],
      "description": "Initial Taskmaster task IDs to dispatch"
    },
    "notes": {
      "type": "string",
      "description": "Optional additional context from OpenClaw"
    }
  },
  "additionalProperties": false
}
